---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Formatter de date simple
const formatDate = (date: Date) => {
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const title = "Nicolas | Architecte de Systèmes QSE Autonomes";
const description = "Publications techniques sur la convergence entre l'IA agentique et la gestion des risques / conformité ISO (9001, 14001, 45001). Conçu pour Marc, Responsable QSE.";
---

<Layout title={title} description={description}>
  <section class="hero-section" style="margin-bottom: 4rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border-color);">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem; letter-spacing: -0.04em;">Systèmes QSE Autonomes</h1>
    <p style="font-size: 1.15rem; color: var(--text-secondary); max-width: 600px; margin-bottom: 0;">
      Je documente en direct la convergence entre l'IA agentique et la gestion des risques ou la conformité ISO.
      Des analyses techniques chirurgicales et pragmatiques, loin du corporate speak.
    </p>
  </section>

  <section>
    <h2 style="font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: none; margin-bottom: 2rem;">
      Toutes les publications
    </h2>
    
    {sortedPosts.length === 0 ? (
      <p style="font-style: italic; color: var(--text-muted);">Aucun article publié pour le moment. Le pipeline Hermes est en cours d'initialisation.</p>
    ) : (
      <div class="post-list">
        {sortedPosts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <span class="post-pilier">{post.data.pilier}</span>
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            </div>
            <h2>
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
            </h2>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    )}
  </section>
</Layout>
