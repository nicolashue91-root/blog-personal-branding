---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Helper pour calculer le temps de lecture
const getReadingTime = (body: string) => {
  const wordsPerMinute = 200;
  const wordCount = body.split(/\s+/).length;
  const minutes = Math.ceil(wordCount / wordsPerMinute);
  return `${minutes} min de lecture`;
};

// Formatter de date simple
const formatDate = (date: Date) => {
  return date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const title = "Nicolas Hue | Architecte de Systèmes QSE Autonomes";
const description = "Publications techniques sur la convergence entre l'IA agentique et la gestion des risques / conformité ISO (9001, 14001, 45001). Conçu pour Marc, Responsable QSE.";

// Séparation de l'article vedette (Featured) et des archives
const featuredPost = sortedPosts[0];
const archivePosts = sortedPosts.slice(1);
---

<Layout title={title} description={description}>
  <section class="hero-section fade-in-entry" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; gap: 2.5rem; flex-wrap: wrap;">
    <div style="flex: 1 1 500px;">
      <h1 style="font-size: 2.85rem; margin-bottom: 0.75rem; letter-spacing: -0.04em; font-weight: 800; line-height: 1.3;">
        Automatiser le QSE. <br />Sans Jamais Perdre le Contrôle.
      </h1>
      <p style="font-size: 1.15rem; color: var(--text-secondary); max-width: 680px; margin-bottom: 0; line-height: 1.625;">
        Responsable QSE en alternance et ingénieur data de formation. Je documente ici comment l'IA agentique peut libérer les équipes QSE de la surcharge administrative, tout en maintenant la conformité ISO.
      </p>
    </div>
    <div style="flex: 0 0 280px; display: flex; justify-content: center; align-items: center; margin: 0 auto;">
      <img src="/images/profile_photo.png" alt="Nicolas Hue" style="width: 250px; height: 320px; object-fit: cover; border-radius: 12px; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); filter: contrast(1.02); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);" class="hero-photo" />
    </div>
  </section>

  {/* Section Principes d'architecture */}
  <section class="principles-section fade-in-entry" style="animation-delay: 0.05s;">
    <h2 style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); border-bottom: none; margin-top: 0; margin-bottom: 1.5rem; font-weight: 700;">
      Principes d'architecture
    </h2>
    <div class="principles-grid">
      <div class="principle-card">
        <div class="principle-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Robustesse</h3>
        <p>Garantir la continuité de service et la résilience du système face aux imprévus opérationnels ou aux données incomplètes du terrain.</p>
      </div>
      <div class="principle-card">
        <div class="principle-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3>Sécurité</h3>
        <p>Protéger les données industrielles sensibles et confiner les risques pour éviter toute propagation d'incident au reste de l'organisation.</p>
      </div>
      <div class="principle-card">
        <div class="principle-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <h3>Déterminisme</h3>
        <p>Assurer des réponses stables, reproductibles et auditables, éliminant toute incertitude ou hallucination pour garantir la conformité ISO.</p>
      </div>
      <div class="principle-card">
        <div class="principle-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3>Efficience</h3>
        <p>Bâtir des architectures d'IA sobres et frugales en ressources, optimisant les coûts d'exploitation et l'empreinte environnementale.</p>
      </div>
    </div>
  </section>

  {sortedPosts.length === 0 ? (
    <p class="empty-state">
      Aucun article publié pour le moment. Le Personal Branding Pipeline est en cours d'initialisation.
    </p>
  ) : (
    <div class="fade-in-entry" style="animation-delay: 0.1s;">
      {/* 1. Article Vedette (Featured Post) */}
      {featuredPost && (
        <article class="featured-card">
          <span class="featured-badge">À la une</span>
          <div class="post-meta">
            <span class="post-pilier">{featuredPost.data.pilier}</span>
            <span style="color: var(--border-color)">•</span>
            <time datetime={featuredPost.data.date.toISOString()}>{formatDate(featuredPost.data.date)}</time>
            <span style="color: var(--border-color)">•</span>
            <span>{getReadingTime(featuredPost.body)}</span>
          </div>
          <h2>
            <a href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
          </h2>
          <p>{featuredPost.data.description}</p>
          <a href={`/blog/${featuredPost.slug}/`} style="font-size: 0.9rem; font-weight: 700; color: var(--accent-color); text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
            Lire l'article complet 
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-top: 1px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </article>
      )}

      {/* 2. Grille des autres articles (Archives) */}
      {archivePosts.length > 0 && (
        <section>
          <h2 style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); border-bottom: none; margin-top: 0.5rem; margin-bottom: 1.5rem; font-weight: 700;">
            Articles précédents
          </h2>
          <div class="post-grid">
            {archivePosts.map((post) => (
              <article class="post-card">
                <div class="post-meta">
                  <span class="post-pilier" style="font-size: 0.75rem;">{post.data.pilier}</span>
                  <span style="color: var(--border-color)">•</span>
                  <time datetime={post.data.date.toISOString()} style="font-size: 0.75rem;">{formatDate(post.data.date)}</time>
                  <span style="color: var(--border-color)">•</span>
                  <span style="font-size: 0.75rem;">{getReadingTime(post.body)}</span>
                </div>
                <h2>
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p>{post.data.description}</p>
              </article>
            ))}
          </div>
        </section>
      )}
    </div>
  )}

  {/* 3. Section Qui suis-je */}
  <section class="about-preview-section">
    <div class="about-preview-container">
      <img src="/images/profile_photo.png" alt="Nicolas Hue" class="about-preview-photo" width="96" height="96" />
      <div class="about-preview-content">
        <h3 class="about-preview-title">Qui suis-je ?</h3>
        <p class="about-preview-text">
          <strong>Nicolas Hue</strong> - Responsable QSE chez Advitam et ingénieur data de formation. Je construis des architectures d'IA agentique pour libérer les équipes QSE du reporting manuel et les recentrer sur le terrain.
        </p>
        <a href="/a-propos" class="about-preview-link">
          En savoir plus 
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-top: 1px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
